generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       Int            @id @default(autoincrement())
  username                 String         @unique
  email                    String?        @unique
  displayName              String?
  passwordHash             String
  avatarUrl                String?
  bio                      String?
  role                     String         @default("viewer") // legacy — kept for backwards compat reads; use roleId going forward
  roleId                   Int?
  groupId                  Int?
  approvalStatus           String         @default("approved")
  emailVerifiedAt          DateTime?
  emailVerificationToken   String?        @unique
  emailVerificationExpires DateTime?
  agent                    Boolean        @default(false)
  createdById              Int?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  directRole               Role?          @relation("UserDirectRole", fields: [roleId], references: [id], onDelete: SetNull)
  group                    Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdBy                User?          @relation("UserProvisioning", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers             User[]         @relation("UserProvisioning")
  entries                  Entry[]        @relation("EntryAuthor")
  comments                 EntryComment[]
  revisions                EntryRevision[]
  favorites                UserFavorite[]
  activityLogs             ActivityLog[]
  shareLinks               ShareLink[]
  notifications            Notification[]
  resetPasswordToken       String?        @unique
  resetPasswordExpires     DateTime?
  notificationPrefs        Json?          @default("{}")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  builtIn     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions Permission[]
  users       User[]       @relation("UserDirectRole")
  groups      Group[]

  @@map("roles")
}

model Group {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  roleId      Int?
  role        Role?   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  users       User[]

  @@map("groups")
}

model Permission {
  id     Int    @id @default(autoincrement())
  roleId Int
  action String // "read" | "create" | "edit" | "delete" | "manage_settings" | "manage_users"
  scope  String // "global" | "own" | "collection" | "entry"
  scopeId Int?   // collection ID or entry ID when scope is "collection" or "entry"

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, action, scope, scopeId])
  @@map("permissions")
}

model Entry {
  id        Int            @id @default(autoincrement())
  docNumber String?        @unique @map("doc_number")
  type      String // opportunity | report | reference | project_note
  source    String // nightly-recon | stock-daily | reddit | web | manual
  title     String
  summary   String?
  content   String?
  status    String         @default("new") // new | interested | in_progress | done | dismissed
  url       String?
  metadata  Json           @default("{}")
  authorId  Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tags        Tag[]          @relation("EntryTags")
  collections Collection[]   @relation("EntryCollections")
  images      EntryImage[]
  author    User?          @relation("EntryAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  deletedAt DateTime?
  deletedBy Int?
  comments  EntryComment[]
  revisions EntryRevision[]
  favorites UserFavorite[]
  shareLinks ShareLink[]
  // Vector search columns (managed via raw SQL for indexing, declared here to prevent db push from dropping them)
  embedding Unsupported("vector(1024)")?
  chunks    EntryChunk[]
}

model EntryImage {
  id        Int      @id @default(autoincrement())
  entryId   Int
  url       String // public URL (MinIO)
  key       String // MinIO object key
  filename  String // original filename
  mimeType  String   @default("image/png")
  size      Int      @default(0) // bytes
  caption   String? // optional description
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model Tag {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}

model EntryComment {
  id        Int      @id @default(autoincrement())
  entryId   Int
  authorId  Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt])
  @@index([authorId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(100)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  tokenPrefix String   @map("token_prefix") @db.VarChar(12)
  userId     Int?      @map("user_id")
  tokenType  String    @default("legacy") @map("token_type") @db.VarChar(32)
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revoked    Boolean   @default(false)

  @@map("api_tokens")
}

model EntryRevision {
  id        Int      @id @default(autoincrement())
  entryId   Int
  authorId  Int?
  title     String
  summary   String?
  content   String?
  status    String
  type      String
  source    String
  url       String?
  metadata  Json     @default("{}")
  tags      String[] // snapshot of tag names at revision time
  editNote  String?  @map("edit_note")
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([entryId, createdAt])
  @@map("entry_revisions")
}

model UserFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  entryId   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId])
  @@map("user_favorites")
}

model Collection {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  color       String?
  parentId    Int?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  docPrefix     String?  @map("doc_prefix")
  docSeqCounter Int      @default(0) @map("doc_seq_counter")

  parent      Collection?  @relation("CollectionTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Collection[] @relation("CollectionTree")
  entries     Entry[]      @relation("EntryCollections")

  @@index([parentId])
  @@map("collections")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String   // "entry.created" | "entry.updated" | "entry.deleted" | "entry.restored" | "comment.created"
  actorId   Int?
  entryId   Int?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entryId])
  @@map("activity_log")
}

model ShareLink {
  id           Int       @id @default(autoincrement())
  token        String    @unique @db.VarChar(64)
  entryId      Int
  createdById  Int
  parentId     Int?
  passwordHash String?   @map("password_hash")
  expiresAt    DateTime?
  maxViews     Int?      @map("max_views")
  viewCount    Int       @default(0) @map("view_count")
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  entry     Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdBy User       @relation(fields: [createdById], references: [id], onDelete: Cascade)
  parent    ShareLink? @relation("ShareLinkChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  ShareLink[] @relation("ShareLinkChildren")

  @@index([entryId])
  @@index([parentId])
  @@map("share_links")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // comment, mention, entry_update, approval, system
  title     String
  body      String?
  link      String?  // e.g. /entries/134
  read      Boolean  @default(false)
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model EntryChunk {
  id          Int      @id @default(autoincrement())
  entryId     Int      @map("entry_id")
  chunkIndex  Int      @default(0) @map("chunk_index")
  chunkText   String   @map("chunk_text")
  contextText String?  @map("context_text")
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime @default(now()) @map("created_at")
  entry       Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId], map: "idx_entry_chunks_entry_id")
  @@map("entry_chunks")
}

model Webhook {
  id        Int      @id @default(autoincrement())
  name      String   @default("")
  url       String
  secret    String
  events    String   // JSON array: ["entry.created", "entry.updated", ...]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

model WebhookDelivery {
  id        Int      @id @default(autoincrement())
  webhookId Int
  event     String
  payload   String   // JSON
  status    Int      // HTTP status code (0 = failed to connect)
  response  String?  // Response body (truncated)
  attempts  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

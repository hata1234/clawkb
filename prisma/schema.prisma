generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       Int            @id @default(autoincrement())
  username                 String         @unique
  email                    String?        @unique
  displayName              String?
  passwordHash             String
  avatarUrl                String?
  bio                      String?
  isAdmin                  Boolean        @default(false) @map("is_admin")
  approvalStatus           String         @default("approved")
  emailVerifiedAt          DateTime?
  emailVerificationToken   String?        @unique
  emailVerificationExpires DateTime?
  agent                    Boolean        @default(false)
  createdById              Int?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  createdBy                User?          @relation("UserProvisioning", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers             User[]         @relation("UserProvisioning")
  groups                   UserGroup[]
  entries                  Entry[]        @relation("EntryAuthor")
  comments                 EntryComment[]
  revisions                EntryRevision[]
  favorites                UserFavorite[]
  activityLogs             ActivityLog[]
  shareLinks               ShareLink[]
  notifications            Notification[]
  resetPasswordToken       String?        @unique
  resetPasswordExpires     DateTime?
  notificationPrefs        Json?          @default("{}")
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  builtIn     Boolean  @default(false) @map("built_in")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users           UserGroup[]
  collectionRoles GroupCollectionRole[]

  @@map("groups")
}

model UserGroup {
  userId  Int @map("user_id")
  groupId Int @map("group_id")
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_groups")
}

model GroupCollectionRole {
  id           Int        @id @default(autoincrement())
  groupId      Int        @map("group_id")
  collectionId Int        @map("collection_id")
  role         String     @default("viewer")
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([groupId, collectionId])
  @@index([collectionId])
  @@map("group_collection_roles")
}

model Entry {
  id        Int            @id @default(autoincrement())
  docNumber String?        @unique @map("doc_number")
  type      String
  source    String
  title     String
  summary   String?
  content   String?
  status    String         @default("new")
  url       String?
  metadata  Json           @default("{}")
  authorId  Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  tags        Tag[]          @relation("EntryTags")
  collections Collection[]   @relation("EntryCollections")
  images      EntryImage[]
  author    User?          @relation("EntryAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  deletedAt DateTime?
  deletedBy Int?
  comments  EntryComment[]
  revisions EntryRevision[]
  favorites UserFavorite[]
  shareLinks ShareLink[]
  bpmnXml   String?  @map("bpmn_xml") @db.Text
  embedding Unsupported("vector(1024)")?
  chunks    EntryChunk[]
  flows     EntryFlow[]
}

model EntryImage {
  id        Int      @id @default(autoincrement())
  entryId   Int
  url       String
  key       String
  filename  String
  mimeType  String   @default("image/png")
  size      Int      @default(0)
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model Tag {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  entries Entry[] @relation("EntryTags")
}

model EntryComment {
  id        Int      @id @default(autoincrement())
  entryId   Int
  authorId  Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([entryId, createdAt])
  @@index([authorId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(100)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  tokenPrefix String   @map("token_prefix") @db.VarChar(12)
  userId     Int?      @map("user_id")
  tokenType  String    @default("legacy") @map("token_type") @db.VarChar(32)
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revoked    Boolean   @default(false)

  @@map("api_tokens")
}

model EntryRevision {
  id        Int      @id @default(autoincrement())
  entryId   Int
  authorId  Int?
  title     String
  summary   String?
  content   String?
  status    String
  type      String
  source    String
  url       String?
  metadata  Json     @default("{}")
  tags      String[]
  editNote  String?  @map("edit_note")
  createdAt DateTime @default(now())
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([entryId, createdAt])
  @@map("entry_revisions")
}

model UserFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  entryId   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([userId, entryId])
  @@map("user_favorites")
}

model Collection {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  color       String?
  parentId    Int?
  sortOrder   Int      @default(0)
  builtIn     Boolean  @default(false) @map("built_in")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  docPrefix     String?  @map("doc_prefix")
  docSeqCounter Int      @default(0) @map("doc_seq_counter")

  parent      Collection?          @relation("CollectionTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Collection[]         @relation("CollectionTree")
  entries     Entry[]              @relation("EntryCollections")
  groupRoles  GroupCollectionRole[]

  @@index([parentId])
  @@map("collections")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  actorId   Int?
  entryId   Int?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entryId])
  @@map("activity_log")
}

model ShareLink {
  id           Int       @id @default(autoincrement())
  token        String    @unique @db.VarChar(64)
  entryId      Int
  createdById  Int
  parentId     Int?
  passwordHash String?   @map("password_hash")
  expiresAt    DateTime?
  maxViews     Int?      @map("max_views")
  viewCount    Int       @default(0) @map("view_count")
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  entry     Entry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdBy User       @relation(fields: [createdById], references: [id], onDelete: Cascade)
  parent    ShareLink? @relation("ShareLinkChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  ShareLink[] @relation("ShareLinkChildren")

  @@index([entryId])
  @@index([parentId])
  @@map("share_links")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model EntryChunk {
  id          Int      @id @default(autoincrement())
  entryId     Int      @map("entry_id")
  chunkIndex  Int      @default(0) @map("chunk_index")
  chunkText   String   @map("chunk_text")
  contextText String?  @map("context_text")
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime @default(now()) @map("created_at")
  entry       Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId], map: "idx_entry_chunks_entry_id")
  @@map("entry_chunks")
}

model EntryFlow {
  id        Int      @id @default(autoincrement())
  entryId   Int      @map("entry_id")
  name      String   @default("") @db.VarChar(200)
  bpmnXml   String   @map("bpmn_xml") @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("entry_flows")
}

model Webhook {
  id        Int      @id @default(autoincrement())
  name      String   @default("")
  url       String
  secret    String
  events    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhooks")
}

model WebhookDelivery {
  id        Int      @id @default(autoincrement())
  webhookId Int
  event     String
  payload   String
  status    Int
  response  String?
  attempts  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clawkb"

# Auth
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3500"

# API Access
API_TOKEN="generate-a-random-token"

# Seed User (used by `npm run seed`)
SEED_USERNAME=admin
SEED_PASSWORD=change-me-on-first-login

# Embedding Provider (ollama or openai)
EMBEDDING_PROVIDER=ollama
EMBEDDING_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
# EMBEDDING_API_KEY=sk-...  # Required for OpenAI

# Object Storage (S3-compatible: MinIO, AWS S3, Cloudflare R2, etc.)
# S3_ENDPOINT=localhost
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=clawkb
# S3_PUBLIC_URL=http://localhost:9000/clawkb
# S3_REGION=us-east-1  # Required for AWS S3

# RAG / Ask AI (LLM endpoint for AI query feature)
# RAG_BASE_URL=http://localhost:8888/v1
# RAG_MODEL=your-model-name
# RAG_API_KEY=

# SMTP (for email notifications and password reset)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
